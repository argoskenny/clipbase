{
  "name": "clipbase-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c green,blue \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --env-file-if-exists=.env.local server/index.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node --env-file-if-exists=.env.local server/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^8.0.13",
    "typescript": "^5.9.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "express": "^5.2.1",
    "cookie-parser": "^1.4.7",
    "lucide-react": "^0.562.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vitest": "^4.0.15",
    "jsdom": "^27.3.0",
    "@types/express": "^5.0.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
